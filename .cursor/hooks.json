{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/pre-commit-check.sh",
        "timeout": 120,
        "matcher": "git\\s+(commit|push)"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/docs-sync-check.sh",
        "timeout": 5
      }
    ]
  }
}
